<?xml version="1.0"?>
<robot name="guido">

  <!-- Wheelchair base -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.70 0.60 0.15"/>
      </geometry>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
    </visual>
  </link>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- LiDAR mount: centered on top of the seatback post -->
  <link name="ldlidar_base"/>
  <joint name="ldlidar_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="ldlidar_base"/>
    <!-- Mounted ~1.0 m above base_link for clear 360-deg FOV -->
    <origin xyz="0.0 0.0 1.0" rpy="0 0 0"/>
  </joint>

</robot>
